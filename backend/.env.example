# =============================================
# COUMT Backend - Variáveis de Ambiente
# =============================================
# Copie este arquivo para .env e preencha os valores

# Servidor
PORT=3000
NODE_ENV=development

# Banco de Dados PostgreSQL
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL="postgresql://postgres:suasenha@localhost:5432/coumt_db"

# JWT (Autenticação)
# Gere uma chave segura: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="sua_chave_jwt_super_secreta_troque_em_producao"
JWT_EXPIRES_IN="7d"

# Frontend (CORS)
FRONTEND_URL="http://localhost:8080"

# Bcrypt (força do hash de senha - quanto maior, mais seguro e mais lento)
BCRYPT_ROUNDS=12
